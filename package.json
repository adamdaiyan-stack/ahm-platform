{
  "name": "ahm-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ingest:prices": "tsx --env-file=.env.local scripts/pipelines/ingest-daily-prices.ts",
    "ingest:index": "tsx --env-file=.env.local scripts/pipelines/ingest-kse-index.ts",
    "sync:snapshots": "tsx --env-file=.env.local scripts/pipelines/sync-company-snapshots.ts",
    "sync:market-index": "tsx --env-file=.env.local scripts/pipelines/sync-market-index.ts",
    "ingest:financials": "tsx --env-file=.env.local scripts/pipelines/ingest-financials.ts",
    "build:daily-snapshots": "tsx --env-file=.env.local scripts/pipelines/build-daily-snapshots.ts",
    "pipeline:all": "npm run ingest:prices && npm run sync:snapshots && npm run sync:market-index && npm run build:daily-snapshots",
    "debug:connector": "tsx --env-file=.env.local scripts/connectors/dps-psx.ts",
    "ingest:announcements": "tsx --env-file=.env.local scripts/pipelines/ingest-announcements.ts",
    "normalize:corp-actions": "tsx --env-file=.env.local scripts/pipelines/normalize-corporate-actions.ts",
    "debug:announcements": "tsx --env-file=.env.local scripts/connectors/psx-announcements.ts",
    "debug:classifier": "tsx --env-file=.env.local scripts/utils/event-classifier.ts",
    "pipeline:events": "npm run ingest:announcements && npm run normalize:corp-actions",
    "reconcile:prices": "tsx --env-file=.env.local scripts/pipelines/reconcile-daily-prices.ts",
    "audit:companies": "tsx --env-file=.env.local scripts/validation/audit-company-master.ts",
    "audit:universe": "tsx --env-file=.env.local scripts/validation/audit-company-universe.ts",
    "audit:universe:json": "tsx --env-file=.env.local scripts/validation/audit-company-universe.ts --json",
    "verify:propagation": "tsx --env-file=.env.local scripts/validation/verify-data-propagation.ts",
    "verify:market-index": "tsx --env-file=.env.local scripts/validation/verify-data-propagation.ts",
    "ingest:financials:apply": "tsx --env-file=.env.local scripts/pipelines/ingest-financials.ts --apply",
    "calc:ratios": "tsx --env-file=.env.local scripts/pipelines/calculate-financial-ratios.ts",
    "compute:peers": "tsx --env-file=.env.local scripts/pipelines/compute-peer-rankings.ts",
    "audit:financials": "tsx --env-file=.env.local scripts/validation/audit-financials.ts",
    "pipeline:financials": "npm run audit:financials && npm run calc:ratios && npm run compute:peers",
    "audit:quality": "tsx --env-file=.env.local scripts/validation/run-quality-checks.ts",
    "audit:quality:json": "tsx --env-file=.env.local scripts/validation/run-quality-checks.ts --json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "esbuild": "^0.28.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
